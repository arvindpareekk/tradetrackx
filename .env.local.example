# Supabase — get these from https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# CoinGecko (free tier — no key needed for public endpoints)
# NEXT_PUBLIC_COINGECKO_API_KEY=your_key_if_pro

# CricAPI — get from https://cricapi.com
NEXT_PUBLIC_CRICAPI_KEY=your_cricapi_key

# API-Football — get from https://rapidapi.com/api-sports
NEXT_PUBLIC_FOOTBALL_API_KEY=your_football_api_key
